<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20230324/MODEL/"
             id="importBase"
             name="Import Base"
             namespace="urn:import-base">

  <inputData id="pointsInput" name="points">
    <variable id="pointsVariable" name="points" typeRef="number"/>
  </inputData>

  <decision id="baseLevel" name="Base Level">
    <variable id="baseLevelVariable" name="Base Level" typeRef="number"/>
    <informationRequirement id="baseLevelNeedsPoints">
      <requiredInput href="#pointsInput"/>
    </informationRequirement>
    <decisionTable id="baseTable" hitPolicy="UNIQUE">
      <input id="pointsColumn" label="Points">
        <inputExpression id="pointsColumnExpression" typeRef="number">
          <text>points</text>
        </inputExpression>
      </input>
      <output id="levelOutput" name="level" typeRef="number"/>
      <rule id="lowPoints">
        <inputEntry id="lowPointsEntry"><text>&lt; 5</text></inputEntry>
        <outputEntry id="lowPointsResult"><text>1</text></outputEntry>
      </rule>
      <rule id="highPoints">
        <inputEntry id="highPointsEntry"><text>&gt;= 5</text></inputEntry>
        <outputEntry id="highPointsResult"><text>2</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
